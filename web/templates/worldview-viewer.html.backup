<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>世界观查看器 - 小说生成系统</title>
    <link rel="stylesheet" href="/static/css/worldview-viewer.css">
    <style>
        /* 简化版样式 */
        .simple-viewer {
            padding: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }
        
        .viewer-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 30px;
            border-radius: 12px;
            margin-bottom: 30px;
            text-align: center;
        }
        
        .viewer-header h1 {
            margin: 0 0 10px 0;
            font-size: 2rem;
        }
        
        .viewer-header p {
            margin: 0;
            opacity: 0.9;
        }
        
        .viewer-section {
            background: white;
            border-radius: 12px;
            padding: 24px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }
        
        .viewer-section h3 {
            margin-top: 0;
            color: #1f2937;
            border-bottom: 2px solid #667eea;
            padding-bottom: 10px;
        }
        
        .faction-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 16px;
            margin-top: 16px;
        }
        
        .faction-card {
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            padding: 16px;
            background: #f9fafb;
        }
        
        .faction-card h4 {
            margin: 0 0 8px 0;
            color: #1f2937;
        }
        
        .location-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .location-list li {
            padding: 12px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .location-list li:last-child {
            border-bottom: none;
        }
        
        .back-btn {
            display: inline-block;
            padding: 10px 20px;
            background: #667eea;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        
        .back-btn:hover {
            background: #5568d3;
        }
    </style>
</head>
<body>
    <!-- 导航栏 -->
    <nav class="navbar">
        <div class="navbar-content">
            <div class="navbar-title">🌍 世界观查看器</div>
            <div class="navbar-actions">
                <a href="/project-management" class="btn btn-secondary">← 返回项目管理</a>
            </div>
        </div>
    </nav>

    <div class="simple-viewer">
        <a href="/project-management" class="back-btn">← 返回项目管理</a>
        
        <!-- 页面标题 -->
        <div class="viewer-header">
            <h1 id="world-title">世界观名称</h1>
            <p id="world-description">世界观描述</p>
        </div>
        
        <!-- 势力信息 -->
        <div class="viewer-section">
            <h3>⚔️ 势力信息</h3>
            <div class="faction-grid" id="factions-container">
                <p style="color: #6b7280;">加载中...</p>
            </div>
        </div>
        
        <!-- 地点信息 -->
        <div class="viewer-section">
            <h3>🗺️ 重要地点</h3>
            <ul class="location-list" id="locations-container">
                <li style="color: #6b7280;">加载中...</li>
            </ul>
        </div>
        
        <!-- 修炼体系 -->
        <div class="viewer-section">
            <h3>🔥 修炼体系</h3>
            <div id="power-system-content">
                <p style="color: #6b7280;">加载中...</p>
            </div>
        </div>
        
        <!-- 法术系统 -->
        <div class="viewer-section">
            <h3>✨ 法术系统</h3>
            <div id="magic-system-content">
                <p style="color: #6b7280;">加载中...</p>
            </div>
        </div>
        
        <!-- 社会制度 -->
        <div class="viewer-section">
            <h3>👥 社会制度</h3>
            <div id="social-system-content">
                <p style="color: #6b7280;">加载中...</p>
            </div>
        </div>
    </div>

    <script src="/static/js/worldview-viewer.js"></script>
    <script src="/static/js/faction-system-modal.js"></script>
</body>
</html>