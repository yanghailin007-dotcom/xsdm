; Supervisor 配置示例
; 将此文件复制到 /etc/supervisor/conf.d/novel_generator.conf

[program:novel_generator]
directory=/path/to/your/project
command=/path/to/your/project/.venv/bin/gunicorn -w 4 -b 127.0.0.1:5000 --timeout 300 --access-logfile logs/access.log --error-logfile logs/error.log web.wsgi:application
user=www-data
autostart=true
autorestart=true
stopasgroup=true
killasgroup=true
stderr_logfile=/var/log/novel_generator/err.log
stdout_logfile=/var/log/novel_generator/out.log
environment=PATH="/path/to/your/project/.venv/bin"
