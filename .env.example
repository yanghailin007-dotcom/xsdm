# 大文娱系统环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 重要：.env 文件不要提交到 Git！

# Flask 安全密钥（必须修改，用于会话加密）
FLASK_SECRET_KEY=your-secret-key-here-change-this-in-production

# 内部API密钥（必须修改，用于内部服务通信）
INTERNAL_API_KEY=your-internal-api-key-change-this-in-production

# 数据库加密密钥（可选）
DB_ENCRYPTION_KEY=

# 调试模式（生产环境设为 false）
FLASK_DEBUG=false

# ==================== 支付配置 ====================
# 易支付商户ID
YIPAY_MERCHANT_ID=YOUR_MERCHANT_ID

# 易支付商户密钥
YIPAY_MERCHANT_KEY=YOUR_MERCHANT_KEY

# 易支付接口地址
YIPAY_API_URL=https://pay.example.com
