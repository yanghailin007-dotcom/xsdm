# ============================================
# 生产环境配置模板 (.env.production)
# 复制此文件为 .env 并填入真实的API密钥
# ============================================

# ============ API 密钥配置 ============
# ⚠️ 警告：以下所有密钥必须替换为真实的生产密钥！

# Gemini API (必需)
GEMINI_API_KEY=your_production_gemini_api_key_here
GEMINI_BASE_URL=https://newapi.xiaochuang.cc/v1/chat/completions

# DeepSeek API (必需)
DEEPSEEK_API_KEY=your_production_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions

# AI-WX 视频生成 API
AIWX_API_KEY=your_production_aiwx_api_key_here

# 豆包 API (图像生成)
ARK_API_KEY=your_production_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL_ID=your_model_id_here

# NanoBanana 图像生成
NANOBANANA_XIAOCHUANG_KEY=your_production_xiaochuang_key_here
NANOBANANA_AIWX_KEY=your_production_aiwx_nanobanana_key_here

# MiniMax TTS 语音合成
MINIMAX_TTS_API_KEY=your_production_minimax_tts_key_here

# ============ Web 服务配置 ============
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=False

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_FILE=logs/novel_generator.log

# ============ 安全配置 ============
# 生产环境建议设置强密钥
SECRET_KEY=your_random_secret_key_here_change_in_production
